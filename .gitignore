# ══════════════════════════════════════════════════
# Whitelist-based .gitignore
# デフォルト全除外 → OSS公開対象のみ許可
# ══════════════════════════════════════════════════

# Step 1: 全て除外
*

# Step 2: ディレクトリの探索を許可（中身は個別に許可）
!*/

# Step 3: OSS公開対象ファイルを許可
!.gitignore
!.gitattributes
!.gitleaks.toml
!CLAUDE.md
!LICENSE
!README.md
!README_ja.md
!CHANGELOG.md
!CONTRIBUTING.md
!SECURITY.md

# Claude Code settings (spinner verbs only, no secrets)
!.claude/
!.claude/settings.json

# Instructions (core OSS)
!instructions/
!instructions/shogun.md
!instructions/karo.md
!instructions/ashigaru.md
!instructions/gunshi.md

# Multi-CLI: CLI-specific tool descriptions
!instructions/cli_specific/
!instructions/cli_specific/claude_tools.md
!instructions/cli_specific/codex_tools.md
!instructions/cli_specific/copilot_tools.md
!instructions/cli_specific/kimi_tools.md
!instructions/cli_specific/opencode_tools.md
!instructions/cli_specific/cursor_tools.md

# Multi-CLI: Build template parts (roles, common sections)
!instructions/roles/
!instructions/roles/*.md
!instructions/common/
!instructions/common/*.md

# Multi-CLI: Generated instruction files (built by build_instructions.sh)
!instructions/generated/
!instructions/generated/*.md

# Multi-CLI: CLI adapter library + ntfy auth
!lib/
!lib/cli_adapter.sh
!lib/ntfy_auth.sh
!lib/agent_status.sh
!lib/agent_registry.sh

# Multi-CLI: Codex auto-load file
!AGENTS.md

# Multi-CLI: OpenCode agent file
!.opencode/agents/*.md
.opencode/agents/*-runtime.md

# Multi-CLI: OpenCode custom tools
!.opencode/tools/
!.opencode/tools/mark-as-read.ts

# Multi-CLI: Cursor Agent skills
!.cursor/skills/
!.cursor/skills/inbox-write/
!.cursor/skills/inbox-write/SKILL.md

# Setup and deployment scripts
!shutsujin_departure.sh
!first_setup.sh
!setup.sh
!install.bat

# Development tooling
!Makefile

# Config (sample files only, no secrets)
!config/
!config/ntfy_auth.env.sample
!config/opencode-tui.json
!config/opencode-permissions.yaml

# Templates
!templates/
!templates/**

# Context README
!context/
!context/README.md

# Python venv
!requirements.txt

# Scripts
!scripts/
!scripts/inbox_write.sh
!scripts/inbox_watcher.sh
!scripts/watcher_supervisor.sh
!scripts/ntfy.sh
!scripts/ntfy_listener.sh
!scripts/build_instructions.sh
!scripts/slim_yaml.sh
!scripts/slim_yaml.py
scripts/seo_qc.py
scripts/seo_qc.sh
!scripts/stop_hook_inbox.sh
!scripts/session_start_hook.sh
!scripts/agent_status.sh
!scripts/ratelimit_check.sh
!scripts/switch_cli.sh
!scripts/dashboard-viewer.py
!scripts/stall_detector.sh
!scripts/mcp_health_check.sh


# SayTask (sample template only, not actual data)
!saytask/
!saytask/streaks.yaml.sample

# Reports (private — not tracked)
logs/

# Memory (MEMORY.md is private; only the sample template is OSS)
!memory/
!memory/MEMORY.md.sample

# Docs
!docs/
!docs/philosophy.md
!docs/vps_pr118_verification_plan.md

# Screenshots (masked — no secrets)
!images/
!images/company-creed-all-panes.png
!images/screenshots/
!images/screenshots/tdd_ndd_rdd.png
!images/screenshots/masked/
!images/screenshots/masked/ntfy_saytask_rename.jpg
