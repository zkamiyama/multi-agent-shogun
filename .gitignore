!images/screenshots/masked/ntfy_tasklist_v2_aligned.jpg
!images/screenshots/hero/
!images/screenshots/hero/latest-translucent-20260210-190453.png
!images/screenshots/hero/latest-translucent-20260208-084602.png

# Skills (public OSS skills committed to repo)
!skills/
!skills/skill-creator/
!skills/skill-creator/SKILL.md
!skills/shogun-agent-status/
!skills/shogun-agent-status/SKILL.md
!skills/shogun-model-list/
!skills/shogun-model-list/SKILL.md
!skills/shogun-bloom-config/
!skills/shogun-bloom-config/SKILL.md
!skills/shogun-model-switch/
!skills/shogun-model-switch/SKILL.md
!skills/shogun-readme-sync/
!skills/shogun-readme-sync/SKILL.md
!skills/shogun-screenshot/
!skills/shogun-screenshot/SKILL.md
!skills/shogun-screenshot/scripts/
!skills/shogun-screenshot/scripts/*.sh
!skills/shogun-screenshot/scripts/*.py

# Python venv (explicit deny — whitelist patterns like LICENSE leak through !*/)
.venv/

# Test specs
!tests/specs/
!tests/specs/*.md
# Client project specs (not OSS — re-exclude after whitelist)
tests/specs/osato_lms_*

# Tests
!tests/
!tests/*.bats
!tests/*.sh
!tests/fixtures/
!tests/fixtures/*.yaml
!tests/fixtures/stall_detector/
!tests/fixtures/stall_detector/**
!tests/unit/
!tests/unit/*.bats
!tests/integration/
!tests/integration/*.bats
!tests/e2e/
!tests/e2e/*.bats
!tests/e2e/mock_cli.sh
!tests/e2e/helpers/
!tests/e2e/helpers/*.bash
!tests/e2e/fixtures/
!tests/e2e/fixtures/*.yaml
!tests/e2e/mock_behaviors/
!tests/e2e/mock_behaviors/*.sh
!tests/test_helper/
!tests/test_helper/README.md

# CI/CD
!.github/
!.github/FUNDING.yml
!.github/workflows/
!.github/workflows/*.yml

# Android companion app
!android/
!android/**

# reports/ (empty placeholder only — content is intentionally local-only)
!reports/
!reports/.gitkeep

.claude/settings.local.json
